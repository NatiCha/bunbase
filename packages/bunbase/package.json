{
  "name": "bunbase",
  "version": "0.0.1",
  "description": "TypeScript-native Backend-as-a-Service built on Bun — REST API, auth, realtime, storage, and admin UI from a Drizzle schema",
  "author": "NatiCha",
  "license": "MIT",
  "keywords": [
    "bunbase",
    "baas",
    "backend",
    "bun",
    "drizzle",
    "rest-api",
    "typescript",
    "sqlite",
    "realtime"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NatiCha/bunbase"
  },
  "homepage": "https://github.com/NatiCha/bunbase#readme",
  "type": "module",
  "bin": {
    "bunbase": "./src/cli/index.ts",
    "create-bunbase": "./src/cli/create.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/types/client.d.ts",
      "default": "./src/client.ts"
    },
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "default": "./src/react/index.tsx"
    },
    "./testing": {
      "types": "./dist/types/testing/index.d.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "type": "bunx tsc --noEmit",
    "test": "bun test",
    "studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=18",
    "@tanstack/react-query": ">=5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^1.0.0-beta.15-859cf75",
    "lucide-react": "^0.574.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4"
  }
}
